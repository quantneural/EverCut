{
  "info": {
    "name": "EverCut - Onboarding",
    "description": "First-time customer and barber onboarding endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{firebase_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "api_prefix",
      "value": "api/v1",
      "type": "string"
    },
    {
      "key": "firebase_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Complete Customer Profile",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/onboarding/customers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "{{api_prefix}}",
            "onboarding",
            "customers"
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "firstName",
              "value": "John",
              "type": "text",
              "description": "Customer first name"
            },
            {
              "key": "lastName",
              "value": "Doe",
              "type": "text",
              "description": "Customer last name"
            },
            {
              "key": "phoneNumber",
              "value": "+1234567890",
              "type": "text",
              "description": "Phone number with country code"
            },
            {
              "key": "email",
              "value": "customer@example.com",
              "type": "text",
              "description": "Email address"
            },
            {
              "key": "gender",
              "value": "Male",
              "type": "text",
              "description": "Male, Female, or Other"
            },
            {
              "key": "dateOfBirth",
              "value": "1990-01-01",
              "type": "text",
              "description": "Date of birth (YYYY-MM-DD)"
            },
            {
              "key": "address",
              "value": "123 Main St, New York, NY",
              "type": "text",
              "description": "Full address"
            },
            {
              "key": "location",
              "value": "{\"type\":\"Point\",\"coordinates\":[-73.935242,40.730610]}",
              "type": "text",
              "description": "GeoJSON Point with [longitude, latitude]"
            },
            {
              "key": "photo",
              "type": "file",
              "src": "",
              "description": "Profile photo (required)"
            }
          ]
        },
        "description": "Complete customer registration with profile photo upload. Creates User and CustomerProfile records.\n\nRequired Fields:\n- firstName, lastName, phoneNumber, email, gender, dateOfBirth, address, location, photo"
      }
    },
    {
      "name": "Complete Barber Profile (New Onboarding)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/onboarding/barbers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "{{api_prefix}}",
            "onboarding",
            "barbers"
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "firstName",
              "value": "John",
              "type": "text",
              "description": "Personal information step"
            },
            {
              "key": "lastName",
              "value": "Doe",
              "type": "text"
            },
            {
              "key": "email",
              "value": "barber@example.com",
              "type": "text"
            },
            {
              "key": "phoneNumber",
              "value": "+919111111111",
              "type": "text"
            },
            {
              "key": "dateOfBirth",
              "value": "1992-01-12",
              "type": "text"
            },
            {
              "key": "gender",
              "value": "Male",
              "type": "text"
            },
            {
              "key": "shopName",
              "value": "Downtown Cuts",
              "type": "text",
              "description": "Business profile step"
            },
            {
              "key": "shopOwner",
              "value": "John Doe",
              "type": "text",
              "description": "Optional alias for the owner/business name shown in the shop profile"
            },
            {
              "key": "businessCategory",
              "value": "Barber",
              "type": "text"
            },
            {
              "key": "targetCustomers",
              "value": "men",
              "type": "text",
              "description": "Accepted: men/women/unisex or male/female/unisex"
            },
            {
              "key": "shopLocation",
              "value": "MG Road, Bengaluru",
              "type": "text"
            },
            {
              "key": "location",
              "value": "{\"type\":\"Point\",\"coordinates\":[77.5946,12.9716]}",
              "type": "text"
            },
            {
              "key": "amenities",
              "value": "[\"Air Conditioning\",\"Waiting Area\",\"Drinking Water\",\"Washrooms\",\"Parking Area\",\"Wi-Fi\",\"Charging Points\"]",
              "type": "text",
              "description": "Amenities step (JSON array)"
            },
            {
              "key": "workingDays",
              "value": "[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\"]",
              "type": "text",
              "description": "Availability step (JSON array)"
            },
            {
              "key": "workingHours",
              "value": "{\"opensAt\":\"09:00\",\"closesAt\":\"20:00\"}",
              "type": "text"
            },
            {
              "key": "breakTimings",
              "value": "[{\"startsAt\":\"13:00\",\"endsAt\":\"14:00\"}]",
              "type": "text",
              "description": "Optional break windows (JSON array)"
            },
            {
              "key": "accountHolderName",
              "value": "John Doe",
              "type": "text",
              "description": "Payout step"
            },
            {
              "key": "bankName",
              "value": "HDFC Bank",
              "type": "text"
            },
            {
              "key": "upiAddress",
              "value": "john@upi",
              "type": "text"
            },
            {
              "key": "pin",
              "value": "1234",
              "type": "text",
              "description": "Exactly 4 digits"
            },
            {
              "key": "confirmPin",
              "value": "1234",
              "type": "text"
            },
            {
              "key": "shopImages",
              "type": "file",
              "src": "",
              "description": "Required image 1/3"
            },
            {
              "key": "shopImages",
              "type": "file",
              "src": "",
              "description": "Required image 2/3"
            },
            {
              "key": "shopImages",
              "type": "file",
              "src": "",
              "description": "Required image 3/3"
            }
          ]
        },
        "description": "Complete barber/shop registration using multipart/form-data.\n\nRequired groups:\n- Personal: firstName, lastName, email/emailId, phoneNumber, dateOfBirth, gender\n- Business: shopName, optional shopOwner/ownerName, businessCategory/shopCategory, targetCustomers, shopLocation/address, location\n- Availability: workingDays/availableDays, workingHours (or openTime + closeTime)\n- Payout: accountHolderName, bankName, upiAddress/upiId\n- Security: pin + confirmPin (exactly 4 digits)\n- Images: exactly 3 files in `shopImages`\n\nResponse data includes created user, the barber shop profile in onboarding-friendly shape, and the initial photo documents."
      }
    }
  ]
}
