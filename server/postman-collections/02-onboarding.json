{
  "info": {
    "name": "EverCut - Onboarding",
    "description": "Customer and barber onboarding requests wired for the Firebase test users and the local sample upload asset.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string",
      "description": "Default local API server"
    },
    {
      "key": "api_prefix",
      "value": "api/v1",
      "type": "string",
      "description": "API prefix used by every request"
    },
    {
      "key": "customer_firebase_token",
      "value": "",
      "type": "string",
      "description": "Paste the ID token for test-customer-001 here"
    },
    {
      "key": "barber_firebase_token",
      "value": "",
      "type": "string",
      "description": "Paste the ID token for test-barber-001 here"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const readScopedValue = (...keys) => {",
          "  for (const key of keys) {",
          "    const environmentValue = pm.environment.get(key);",
          "    if (environmentValue) return environmentValue;",
          "    const globalValue = pm.globals.get(key);",
          "    if (globalValue) return globalValue;",
          "  }",
          "  return '';",
          "};",
          "const baseUrl = readScopedValue('base_url');",
          "if (baseUrl) { pm.collectionVariables.set('base_url', baseUrl); }",
          "const apiPrefix = readScopedValue('api_prefix');",
          "if (apiPrefix) { pm.collectionVariables.set('api_prefix', apiPrefix); }",
          "const customerToken = readScopedValue('customer_firebase_token');",
          "if (customerToken) { pm.collectionVariables.set('customer_firebase_token', customerToken); }",
          "const barberToken = readScopedValue('barber_firebase_token');",
          "if (barberToken) { pm.collectionVariables.set('barber_firebase_token', barberToken); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Complete Customer Profile",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{base_url}}/{{api_prefix}}/onboarding/customers",
        "description": "Creates the customer profile for test-customer-001. A rerun returns 409 because onboarding only succeeds once per Firebase user.",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "firstName",
              "value": "Test",
              "type": "text"
            },
            {
              "key": "lastName",
              "value": "Customer",
              "type": "text"
            },
            {
              "key": "phoneNumber",
              "value": "+15550000001",
              "type": "text"
            },
            {
              "key": "email",
              "value": "test.customer@example.com",
              "type": "text"
            },
            {
              "key": "gender",
              "value": "Male",
              "type": "text"
            },
            {
              "key": "dateOfBirth",
              "value": "1994-06-15",
              "type": "text"
            },
            {
              "key": "address",
              "value": "Church Street, Bengaluru",
              "type": "text"
            },
            {
              "key": "location",
              "value": "{\"type\":\"Point\",\"coordinates\":[77.5946,12.9716]}",
              "type": "text",
              "description": "GeoJSON point near the barber test shop"
            },
            {
              "key": "photo",
              "type": "file",
              "src": "C:\\Users\\manis\\Projects\\EverCut\\server\\postman-collections\\assets\\sample-upload.png",
              "description": "Prewired local sample upload"
            }
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{customer_firebase_token}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201 or 409', function () { pm.expect(pm.response.code).to.be.oneOf([201, 409]); });"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Complete Barber Profile",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{base_url}}/{{api_prefix}}/onboarding/barbers",
        "description": "Creates the barber shop for test-barber-001. The three shop image fields already point to the local sample file.",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "firstName",
              "value": "Test",
              "type": "text"
            },
            {
              "key": "lastName",
              "value": "Barber",
              "type": "text"
            },
            {
              "key": "email",
              "value": "test.barber@example.com",
              "type": "text"
            },
            {
              "key": "phoneNumber",
              "value": "+15550000002",
              "type": "text"
            },
            {
              "key": "dateOfBirth",
              "value": "1991-01-12",
              "type": "text"
            },
            {
              "key": "gender",
              "value": "Male",
              "type": "text"
            },
            {
              "key": "shopName",
              "value": "Postman Test Barber Studio",
              "type": "text"
            },
            {
              "key": "shopOwner",
              "value": "Test Barber",
              "type": "text"
            },
            {
              "key": "businessCategory",
              "value": "Barber",
              "type": "text"
            },
            {
              "key": "targetCustomers",
              "value": "male",
              "type": "text"
            },
            {
              "key": "shopLocation",
              "value": "MG Road, Bengaluru",
              "type": "text"
            },
            {
              "key": "location",
              "value": "{\"type\":\"Point\",\"coordinates\":[77.5946,12.9716]}",
              "type": "text",
              "description": "Matches the customer discovery coordinates"
            },
            {
              "key": "amenities",
              "value": "[\"Air Conditioning\",\"Waiting Area\",\"Drinking Water\",\"Washrooms\",\"Parking Area\",\"Wi-Fi\",\"Charging Points\"]",
              "type": "text"
            },
            {
              "key": "workingDays",
              "value": "[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\"]",
              "type": "text"
            },
            {
              "key": "workingHours",
              "value": "{\"opensAt\":\"09:00\",\"closesAt\":\"20:00\"}",
              "type": "text"
            },
            {
              "key": "breakTimings",
              "value": "[{\"startsAt\":\"13:00\",\"endsAt\":\"14:00\"}]",
              "type": "text"
            },
            {
              "key": "accountHolderName",
              "value": "Test Barber",
              "type": "text"
            },
            {
              "key": "bankName",
              "value": "HDFC Bank",
              "type": "text"
            },
            {
              "key": "upiAddress",
              "value": "test.barber@upi",
              "type": "text"
            },
            {
              "key": "pin",
              "value": "1234",
              "type": "text"
            },
            {
              "key": "confirmPin",
              "value": "1234",
              "type": "text"
            },
            {
              "key": "shopImages",
              "type": "file",
              "src": "C:\\Users\\manis\\Projects\\EverCut\\server\\postman-collections\\assets\\sample-upload.png",
              "description": "Sample shop image 1 of 3"
            },
            {
              "key": "shopImages",
              "type": "file",
              "src": "C:\\Users\\manis\\Projects\\EverCut\\server\\postman-collections\\assets\\sample-upload.png",
              "description": "Sample shop image 2 of 3"
            },
            {
              "key": "shopImages",
              "type": "file",
              "src": "C:\\Users\\manis\\Projects\\EverCut\\server\\postman-collections\\assets\\sample-upload.png",
              "description": "Sample shop image 3 of 3"
            }
          ]
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{barber_firebase_token}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201 or 409', function () { pm.expect(pm.response.code).to.be.oneOf([201, 409]); });",
              "const response = pm.response.code === 201 ? pm.response.json() : null;",
              "const shopId = response && response.data && response.data.shop && response.data.shop._id;",
              "if (shopId) { pm.globals.set('shared_shop_id', shopId); }",
              "if (pm.response.code === 201) { pm.globals.set('shared_barber_pin', '1234'); }"
            ]
          }
        }
      ]
    }
  ]
}
