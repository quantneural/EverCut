{
  "info": {
    "name": "EverCut - Barber Profile & Shop",
    "description": "Barber shop profile and business management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{firebase_token}}", "type": "string"}]},
  "variable": [
    {"key": "base_url", "value": "http://localhost:5000", "type": "string"},
    {"key": "api_prefix", "value": "api/v1", "type": "string"},
    {"key": "firebase_token", "value": "", "type": "string"}
  ],
  "item": [
    {"name": "Get Profile", "request": {"method": "GET", "header": [], "url": {"raw": "{{base_url}}{{api_prefix}}/barber/profile", "host": ["{{base_url}}"], "path": ["{{api_prefix}}", "barber", "profile"]}, "description": "Get barber shop profile (excludes PIN hash for security)."}},
    {"name": "Update Business Info", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "url": {"raw": "{{base_url}}{{api_prefix}}/barber/profile", "host": ["{{base_url}}"], "path": ["{{api_prefix}}", "barber", "profile"]}, "body": {"mode": "raw", "raw": "{\n  \"shopName\": \"Updated Shop Name\",\n  \"bio\": \"Updated bio and description\",\n  \"facilities\": [\"Air Conditioning\", \"Waiting Area\", \"Parking Area\", \"Wi-Fi\"],\n  \"openTime\": \"08:00\",\n  \"closeTime\": \"21:00\",\n  \"availableDays\": [\"Monday\", \"Tuesday\", \"Wednesday\", \"Thursday\", \"Friday\", \"Saturday\", \"Sunday\"]\n}", "options": {"raw": {"language": "json"}}}, "description": "Update shop business information. All fields are optional."}},
    {"name": "Update PIN", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "url": {"raw": "{{base_url}}{{api_prefix}}/barber/profile/pin", "host": ["{{base_url}}"], "path": ["{{api_prefix}}", "barber", "profile", "pin"]}, "body": {"mode": "raw", "raw": "{\n  \"currentPin\": \"1234\",\n  \"newPin\": \"5678\",\n  \"confirmPin\": \"5678\"\n}", "options": {"raw": {"language": "json"}}}, "description": "Update shop access PIN (exactly 4 digits)."}},
    {"name": "Update Cover Image", "request": {"method": "PUT", "header": [], "url": {"raw": "{{base_url}}{{api_prefix}}/barber/profile/cover", "host": ["{{base_url}}"], "path": ["{{api_prefix}}", "barber", "profile", "cover"]}, "body": {"mode": "formdata", "formdata": [{"key": "cover", "type": "file", "src": "", "description": "Shop cover image"}]}, "description": "Update shop cover image (uploaded to Cloudinary)."}},
    {"name": "Toggle Shop Status", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "url": {"raw": "{{base_url}}{{api_prefix}}/barber/profile/toggle-status", "host": ["{{base_url}}"], "path": ["{{api_prefix}}", "barber", "profile", "toggle-status"]}, "body": {"mode": "raw", "raw": "{\n  \"isOpen\": true\n}", "options": {"raw": {"language": "json"}}}, "description": "Open or close shop. If isOpen not provided, it toggles current status."}}
  ]
}
