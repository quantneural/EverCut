{
  "info": {
    "name": "EverCut - Barber Earnings",
    "description": "Earnings tracking for barber shops",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{firebase_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "api_prefix",
      "value": "api/v1",
      "type": "string"
    },
    {
      "key": "firebase_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Get Earnings",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/barber/earnings",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "{{api_prefix}}",
            "barber",
            "earnings"
          ]
        },
        "description": "Get earnings summary from completed bookings.\n\nResponse:\n{\n  \"success\": true,\n  \"data\": {\n    \"totalEarning\": 50000,\n    \"lastMonthEarning\": 15000,\n    \"todayEarning\": 2500\n  }\n}"
      }
    }
  ]
}
