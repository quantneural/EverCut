# ──────────────────────────────────────────────────────────────────────────
# EverCut Backend — Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# NEVER commit the `.env` file to version control.
# ──────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001
LOG_LEVEL=debug

# ── MongoDB ──────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>/<dbname>
MONGODB_URI=mongodb+srv://your_user:your_password@your-cluster.mongodb.net/evercut?retryWrites=true&w=majority

# ── Firebase ─────────────────────────────────────────────────────────────
# Path to the Firebase service account key JSON file (relative to project root)
# Generate from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-admin-sdk.json

# Firebase Web API Key (for token generation script)
# Get from: Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY=your_web_api_key

# ── Cloudinary ───────────────────────────────────────────────────────────
# Get these from: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS (Production) ───────────────────────────────────────────────────
# Comma-separated list of allowed origins (only used when NODE_ENV=production)
# ALLOWED_ORIGINS=https://your-frontend.com,https://admin.your-frontend.com
